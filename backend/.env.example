APP_NAME="AI Business Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=ai_business_platform
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# AI Assistant — any OpenAI-compatible Chat Completions endpoint.
# Example below targets Gemini's OpenAI-compatible endpoint
# (https://ai.google.dev/gemini-api/docs/openai) — get a key from Google
# AI Studio. Swap AI_BASE_URL/AI_API_KEY/AI_MODEL to point at OpenRouter
# (https://openrouter.ai/api/v1) or a local Ollama instead — no code
# changes needed either way, this is a config-only switch.
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
AI_API_KEY=
AI_MODEL=gemini-flash-latest
# Embeddings default to the chat provider above if left unset. Set these to
# route embeddings at a different endpoint than chat (e.g. keep embeddings
# on a different provider whose embedding-model coverage differs from its
# chat coverage).
AI_EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
AI_EMBEDDING_API_KEY=
AI_EMBEDDING_MODEL=gemini-embedding-001
# Optional OpenRouter attribution headers (dashboard/rankings only; ignored
# by Gemini, Ollama, and other providers that don't recognize them).
AI_SITE_URL=
AI_SITE_NAME="AI Business Platform"

VITE_APP_NAME="${APP_NAME}"
